# Absolute path to your Obsidian root folder
OBSIDIAN_ROOT=/path/to/your/obsidian/vault

# Absolute path to the folder where generated EPUBs will be saved
EPUB_DESTINATION=/path/to/save/epubs

# Default Author for your Ebooks (Optional)
# If left empty or removed, it will default to "Unknown Author"
DEFAULT_AUTHOR="Your Name"

# Default Publisher (Optional)
# DEFAULT_PUBLISHER="My Personal Notes"

# ==== SEND TO KINDLE SETTINGS (OPTIONAL) ====
# The email of your Kindle device
# KINDLE_EMAIL="tu_nombre_123@kindle.com"

# Your Gmail address (Must be approved on Amazon's Personal Document Settings)
# SMTP_USER="tu_correo@gmail.com"

# Your Gmail App Password (NOT your regular password)
# SMTP_PASSWORD="abcd efgh ijkl mnop"

